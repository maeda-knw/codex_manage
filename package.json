{
  "name": "codex-thread-manager",
  "displayName": "Codex Thread Manager",
  "description": "Manage Codex threads for the current VS Code workspace.",
  "version": "0.0.1",
  "publisher": "codex-thread-manager",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kannou/codex_manage.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:codexThreadManager.threads",
    "onWebviewPanel:codexThreadManager.conversation"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexThreadManager",
          "title": "Codex",
          "icon": "resources/codex.svg"
        }
      ]
    },
    "views": {
      "codexThreadManager": [
        {
          "id": "codexThreadManager.threads",
          "name": "Threads",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codexThreadManager.refresh",
        "title": "Refresh Threads",
        "category": "Codex Thread Manager",
        "icon": "$(refresh)"
      },
      {
        "command": "codexThreadManager.openSettings",
        "title": "Open Settings",
        "category": "Codex Thread Manager",
        "icon": "$(gear)"
      },
      {
        "command": "codexThreadManager.openThread",
        "title": "Open Thread Conversation",
        "category": "Codex Thread Manager",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "codexThreadManager.pin",
        "title": "Pin Thread",
        "category": "Codex Thread Manager",
        "icon": "$(pinned)"
      },
      {
        "command": "codexThreadManager.unpin",
        "title": "Unpin Thread",
        "category": "Codex Thread Manager",
        "icon": "$(pinned-dirty)"
      },
      {
        "command": "codexThreadManager.rename",
        "title": "Rename Thread",
        "category": "Codex Thread Manager",
        "icon": "$(edit)"
      },
      {
        "command": "codexThreadManager.archive",
        "title": "Archive Thread",
        "category": "Codex Thread Manager",
        "icon": "$(archive)"
      },
      {
        "command": "codexThreadManager.unarchive",
        "title": "Restore Thread",
        "category": "Codex Thread Manager",
        "icon": "$(history)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codexThreadManager.refresh",
          "when": "view == codexThreadManager.threads",
          "group": "navigation@1"
        },
        {
          "command": "codexThreadManager.openSettings",
          "when": "view == codexThreadManager.threads",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Codex Thread Manager",
      "properties": {
        "codexThreadManager.codexPath": {
          "type": "string",
          "default": "codex",
          "description": "Codex CLI executable or official npm shim. The default automatically resolves native PATH installs before npm shims."
        },
        "codexThreadManager.pageSize": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 200,
          "description": "Number of threads to request per page."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run typecheck && npm run typecheck:webview && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:webview": "tsc --noEmit -p tsconfig.webview.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "test": "node scripts/run-tests.mjs",
    "test:vscode": "npm run build && node scripts/run-vscode-tests.mjs",
    "verify:package-files": "node scripts/verify-package-contents.mjs",
    "verify": "npm run test && npm run typecheck && npm run typecheck:webview && npm run typecheck:test && npm run lint && npm run build && npm run verify:package-files",
    "generate:protocol": "node scripts/generate-protocol.mjs",
    "package": "npm run build && npm run verify:package-files && vsce package --no-dependencies",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@openai/codex": "0.144.2",
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.92.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4"
  }
}
